---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import BadgeEpistemico from '../../../components/BadgeEpistemico.astro';
import CapaTag from '../../../components/CapaTag.astro';
import { fecha, fechaISO } from '../../../utils/fecha';
import { t, idiomaPorDefecto as idioma } from '../../../i18n/ui';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({ params: { slug: paper.id }, props: { paper } }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);
---

<Base titulo={paper.data.titulo} descripcion={paper.data.key_insight}>
  <article class="contenedor">
    <header class="cabecera">
      <p class="meta">
        <BadgeEpistemico registro={paper.data.registro} />
        {paper.data.capas.map((c) => <CapaTag capa={c} />)}
      </p>
      <h1>{paper.data.titulo}</h1>
      <p class="mono autores">{paper.data.autores} · {paper.data.fuente}</p>
      <p class="mono detalle">
        <a href={paper.data.url} rel="noopener">{t(idioma, 'accion.fuente_original')} ↗</a>
        · lectura: {paper.data.lectura} ·
        <time datetime={fechaISO(paper.data.fecha_lectura)}>{fecha(paper.data.fecha_lectura)}</time>
      </p>
    </header>

    <blockquote class="insight">
      <p><strong>Key insight:</strong> {paper.data.key_insight}</p>
    </blockquote>

    <div class="prosa">
      <Content />
    </div>
  </article>
</Base>

<style>
  .cabecera {
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-4);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .autores { color: var(--text-muted); margin: 0 0 var(--space-2); }
  .detalle { color: var(--text-faint); margin: 0; }

  .insight {
    border-left-color: var(--frio);
    margin-bottom: var(--space-4);
  }
</style>
