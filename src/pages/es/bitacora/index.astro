---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import BadgeEpistemico from '../../../components/BadgeEpistemico.astro';
import CapaTag from '../../../components/CapaTag.astro';
import { fecha, fechaISO } from '../../../utils/fecha';

const entradas = (await getCollection('bitacora')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
);
const base = import.meta.env.BASE_URL;
---

<Base
  titulo="Bitácora"
  descripcion="Síntesis fechadas: el pensamiento en evolución. Hipótesis en observación, etiquetadas E3/E4."
>
  <div class="contenedor">
    <p class="kicker">Bitácora · síntesis fechadas</p>
    <h1>Bitácora</h1>
    <p class="lede">
      El pensamiento en evolución. Cada entrada nace de una semilla — conversación,
      lectura, meditación, sincronicidad — y queda fechada como hipótesis en observación.
      La experiencia en primera persona es dato; su interpretación es hipótesis.
    </p>

    <ul class="lista-cards">
      {
        entradas.map((entrada) => (
          <li>
            <a class="card" href={`${base}es/bitacora/${entrada.id}/`}>
              <span class="meta">
                <BadgeEpistemico registro={entrada.data.registro} />
                {entrada.data.capas.map((c) => (
                  <CapaTag capa={c} enlace={false} />
                ))}
                <span class="mono semilla">semilla: {entrada.data.semilla}</span>
              </span>
              <h3>{entrada.data.titulo}</h3>
              <p class="mono fecha">
                <time datetime={fechaISO(entrada.data.fecha)}>{fecha(entrada.data.fecha)}</time>
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Base>

<style>
  .semilla { color: var(--calido-suave); }
  .fecha { color: var(--text-faint); margin: 0; }
</style>
